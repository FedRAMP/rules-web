  "pictographs": {
    "source": {
      "machine": ":lucide-computer:{ .machine }",
      "person": ":lucide-person-standing:{ .person }"
    },
    "status": {
      "stable": ":lucide-book-open-check:{ .stable }",
      "placeholder": ":lucide-pencil:{ .placeholder }",
      "empty": ":lucide-circle-slash:{ .empty }"
    },
    "tooltips": {
      "machine": "This content is machine-generated from FedRAMP Machine-Readable Rules.",
      "person": "This content was written by a human just for this page.",
      "stable": "This content is relatively stable and only minor changes are expected.",
      "placeholder": "This content is a placeholder and is not complete.",
      "empty": "This content has not been produced or ported to this website yet."
    }
  },
  "generated": {
    "manifest": ".generated-markdown.json",
    "todo": {
      "title": "TO DO",
      "output": "todo.md",
      "source": "machine",
      "status": "placeholder",
      "description": "A table showing all pages, their source, and their progress along with links to internal documentation only available to FedRAMP.",
      "purpose": "The FedRAMP team will have a simple place to see progress that is machine-generated."
    },
    "definitionDocuments": [
      {
        "id": "fedramp-definitions",
        "title": "FedRAMP Definitions",
        "output": "definitions.md",
        "status": "stable",
        "includeEffectiveDates": false,
        "source": {
          "collection": "FRD",
          "types": ["20x", "rev5"],
          "includeBoth": true,
          "bothPosition": "first"
        }
      }
    ],
    "ksiDocuments": [
